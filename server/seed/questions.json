    "slug": "department-employee-count",
    "description": "Find total employees in each department.",
    "difficulty": "Medium",
    "topics": ["GROUP BY", "COUNT"],
    "companies": ["Microsoft"],
    "schema": {
      "tables": [
        {
          "name": "employees",
          "columns": [
            {"name": "id", "type": "INT", "constraints": []},
            {"name": "department", "type": "TEXT", "constraints": []}
          ],
          "sampleData": [
            [1, "HR"],
            [2, "IT"],
            [3, "IT"]
          ]
        }
      ]
    },
    "examples": [
      {
        "description": "Count employees per department",
        "expectedColumns": ["department", "total"],
        "expectedOutput": [
          ["IT", 2],
          ["HR", 1]
        ]
